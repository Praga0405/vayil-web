NODE_ENV=development
PORT=9090
CORS_ORIGIN=http://localhost:3000,https://vayil.in,https://ops.vayil.in

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=vayil

JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
JWT_EXPIRES_IN=30d
STAFF_JWT_SECRET=change-me-staff-secret

TWO_FACTOR_API_KEY=
OTP_BYPASS=false
OTP_BYPASS_CODE=123456

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret — Razorpay dashboard → Webhooks → Add → Secret.
# Used by /payments/webhooks/razorpay for HMAC verification.
RAZORPAY_WEBHOOK_SECRET=

AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
